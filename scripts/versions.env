# Default build configuration for reproducible builds.
# Override these values locally, or pass them inline:
#   LIBTORRENT_REF=latest ./scripts/release.sh 0.1.0
#   BOOST_INCLUDE_DIR=/path/to/boost ./scripts/build-apple-libs.sh

: "${LIBTORRENT_REPO_URL:=https://github.com/arvidn/libtorrent.git}"
: "${LIBTORRENT_REF:=v2.0.11}"

# Libtorrent 2.0 only needs Boost headers on the CMake path used by this repo.
: "${BOOST_VERSION:=1.76.0}"
: "${BOOST_SOURCE_URL:=https://archives.boost.io/release/${BOOST_VERSION}/source/boost_${BOOST_VERSION//./_}.tar.bz2}"

: "${IOS_DEPLOYMENT_TARGET:=15.0}"
: "${MACOS_DEPLOYMENT_TARGET:=13.0}"
: "${FRAMEWORK_NAME:=LibtorrentAppleBinary}"
